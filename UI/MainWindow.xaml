<Window x:Class="VoidVPN.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoidVPN"
        Height="520" Width="360"
        MinHeight="520" MinWidth="360"
        MaxWidth="360"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        FontFamily="Segoe UI"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

  <Window.Resources>
    <!-- ══ Theme brushes — mutated in-place for smooth Lerp transition ══ -->
    <SolidColorBrush x:Key="Br.Bg"        Color="#FF0C0C0C"/>
    <SolidColorBrush x:Key="Br.Fg"        Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="Br.Muted"     Color="#FF555555"/>
    <SolidColorBrush x:Key="Br.Border"    Color="#FF2A2A2A"/>
    <SolidColorBrush x:Key="Br.StatusDot" Color="#FF333333"/>
    <SolidColorBrush x:Key="Br.DotA"      Color="#FF000000"/>
    <SolidColorBrush x:Key="Br.DotB"      Color="#FFFFFFFF"/>

    <!-- ══ 3-dot animation ═══════════════════════════════════════════════ -->
    <Storyboard x:Key="DotsAnim" RepeatBehavior="Forever">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1"
                                     Storyboard.TargetProperty="(Canvas.Left)">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="40">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="40">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="0">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="0"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2"
                                     Storyboard.TargetProperty="(Canvas.Left)">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="20"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="20">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="0">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="40">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="20"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3"
                                     Storyboard.TargetProperty="(Canvas.Left)">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="40"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="0">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="20">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="20">
          <EasingDoubleKeyFrame.EasingFunction>
            <CubicEase EasingMode="EaseInOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="40"/>
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <!-- ══ View fade ════════════════════════════════════════════════════ -->
    <Storyboard x:Key="FadeIn">
      <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2">
        <DoubleAnimation.EasingFunction>
          <CubicEase EasingMode="EaseOut"/>
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
    </Storyboard>

    <!-- ══ Button — animated opacity hover ═════════════════════════════ -->
    <Style x:Key="Btn" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="{DynamicResource Br.Fg}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource Br.Fg}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="FontSize"        Value="10"/>
      <Setter Property="FontWeight"      Value="Light"/>
      <Setter Property="Padding"         Value="28,9"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Opacity"         Value="1"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.15"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.45" Duration="0:0:0.13">
                <DoubleAnimation.EasingFunction>
                  <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                  <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.22" Duration="0:0:0.05"/>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SmBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
      <Setter Property="FontSize"  Value="9"/>
      <Setter Property="Padding"   Value="10,5"/>
    </Style>

    <!-- Chrome control buttons (tray / close) -->
    <Style x:Key="ChromeBtn" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontSize"        Value="9"/>
      <Setter Property="FontWeight"      Value="Light"/>
      <Setter Property="Foreground"      Value="{DynamicResource Br.Muted}"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Opacity"         Value="1"/>
      <Setter Property="Padding"         Value="6,3"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.18"/>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </Style.Triggers>
    </Style>

    <!-- Ghost button (LOG COPY / CLEAR) -->
    <Style x:Key="GhostBtn" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontSize"        Value="8"/>
      <Setter Property="FontWeight"      Value="Light"/>
      <Setter Property="Foreground"      Value="{DynamicResource Br.Muted}"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Opacity"         Value="0.5"/>
      <Setter Property="Padding"         Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <TextBlock Text="{TemplateBinding Content}"
                       Foreground="{TemplateBinding Foreground}"
                       FontSize="{TemplateBinding FontSize}"
                       FontWeight="{TemplateBinding FontWeight}"/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.18"/>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </Style.Triggers>
    </Style>

    <!-- TextBox -->
    <Style x:Key="Input" TargetType="TextBox">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="{DynamicResource Br.Fg}"/>
      <Setter Property="CaretBrush"      Value="{DynamicResource Br.Fg}"/>
      <Setter Property="SelectionBrush"  Value="{DynamicResource Br.Muted}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource Br.Muted}"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="FontSize"        Value="11"/>
      <Setter Property="FontWeight"      Value="Light"/>
      <Setter Property="Padding"         Value="0,5"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ListBoxItem with animated hover -->
    <Style x:Key="KeyCard" TargetType="ListBoxItem">
      <Setter Property="Background"                 Value="Transparent"/>
      <Setter Property="Foreground"                 Value="{DynamicResource Br.Fg}"/>
      <Setter Property="Padding"                    Value="0"/>
      <Setter Property="Margin"                     Value="0"/>
      <Setter Property="BorderThickness"            Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
      <Setter Property="Opacity"                    Value="1"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{DynamicResource Br.Border}"
                    BorderThickness="0,0,0,1"
                    Padding="0,8">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#0DFFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.13">
                <DoubleAnimation.EasingFunction>
                  <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                  <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </Style.Triggers>
    </Style>

    <!-- ══ Minimal custom horizontal scrollbar ═══════════════════════════
             Used in the log area to scroll wide log lines left/right.
             Height 4px, track transparent, thumb uses Br.Muted colour.          -->
    <Style x:Key="MinimalHScrollBar" TargetType="ScrollBar">
      <Setter Property="Orientation" Value="Horizontal"/>
      <Setter Property="Height"      Value="4"/>
      <Setter Property="MinHeight"   Value="4"/>
      <Setter Property="Background"  Value="Transparent"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid>
              <Track x:Name="PART_Track" IsDirectionReversed="False">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="ScrollBar.PageLeftCommand"
                                Background="Transparent" BorderThickness="0"
                                Opacity="0" Focusable="False"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb>
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource Br.Muted}"
                                CornerRadius="2"
                                Opacity="0.5"
                                Margin="0,1"/>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                          </Trigger>
                          <Trigger Property="IsDragging" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="ScrollBar.PageRightCommand"
                                Background="Transparent" BorderThickness="0"
                                Opacity="0" Focusable="False"/>
                </Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ScrollViewer using the custom horizontal scrollbar -->
    <Style x:Key="LogScrollViewer" TargetType="ScrollViewer">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollViewer">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <!-- Content -->
              <ScrollContentPresenter Grid.Row="0"
                                      CanContentScroll="{TemplateBinding CanContentScroll}"/>
              <!-- Custom horizontal scrollbar -->
              <ScrollBar Grid.Row="1"
                         x:Name="PART_HorizontalScrollBar"
                         Style="{StaticResource MinimalHScrollBar}"
                         Value="{TemplateBinding HorizontalOffset}"
                         Maximum="{TemplateBinding ScrollableWidth}"
                         ViewportSize="{TemplateBinding ViewportWidth}"
                         Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Log row styles — separate named styles (no BasedOn inside DataTemplate) -->
    <Style x:Key="LogTime" TargetType="TextBlock">
      <Setter Property="FontFamily"   Value="Consolas"/>
      <Setter Property="FontSize"     Value="9"/>
      <Setter Property="Foreground"   Value="{DynamicResource Br.Muted}"/>
      <Setter Property="Opacity"      Value="0.55"/>
      <Setter Property="TextWrapping" Value="NoWrap"/>
    </Style>
    <Style x:Key="LogMsg" TargetType="TextBlock">
      <Setter Property="FontFamily"   Value="Consolas"/>
      <Setter Property="FontSize"     Value="9"/>
      <Setter Property="Foreground"   Value="{DynamicResource Br.Fg}"/>
      <Setter Property="Opacity"      Value="0.6"/>
      <Setter Property="TextWrapping" Value="NoWrap"/>
      <Setter Property="Margin"       Value="3,0,0,0"/>
    </Style>
    <Style x:Key="LogTag" TargetType="TextBlock">
      <Setter Property="FontFamily"   Value="Consolas"/>
      <Setter Property="FontSize"     Value="9"/>
      <Setter Property="Foreground"   Value="{DynamicResource Br.Muted}"/>
      <Setter Property="Opacity"      Value="0.5"/>
      <Setter Property="TextWrapping" Value="NoWrap"/>
      <Setter Property="Margin"       Value="3,0,0,0"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding Tag}" Value="ERR">
          <Setter Property="Foreground" Value="#CC3333"/>
          <Setter Property="Opacity"    Value="1"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding Tag}" Value="WRN">
          <Setter Property="Foreground" Value="#BB8800"/>
          <Setter Property="Opacity"    Value="1"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- ══ ComboBox — minimal style matching app design ════════════════ -->
    <Style x:Key="ProfileCombo" TargetType="ComboBox">
      <Setter Property="Background"       Value="Transparent"/>
      <Setter Property="Foreground"       Value="{DynamicResource Br.Fg}"/>
      <Setter Property="BorderBrush"      Value="{DynamicResource Br.Muted}"/>
      <Setter Property="BorderThickness"  Value="0,0,0,1"/>
      <Setter Property="FontSize"         Value="10"/>
      <Setter Property="FontWeight"       Value="Light"/>
      <Setter Property="Padding"          Value="0,5"/>
      <Setter Property="Cursor"           Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <Border BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      Background="{TemplateBinding Background}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <ContentPresenter Grid.Column="0"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="Center"/>
                  <!-- Arrow indicator -->
                  <TextBlock Grid.Column="1"
                             Text="▾"
                             FontSize="8"
                             Foreground="{DynamicResource Br.Muted}"
                             VerticalAlignment="Center"
                             Margin="4,0,0,0"
                             Opacity="0.6"/>
                </Grid>
              </Border>
              <Popup x:Name="PART_Popup"
                     IsOpen="{TemplateBinding IsDropDownOpen}"
                     AllowsTransparency="True"
                     Focusable="False"
                     PopupAnimation="Slide">
                <!-- FIX 1: MinWidth привязан к ширине ComboBox — дропдаун растягивается на полную строку -->
                <Border Background="{DynamicResource Br.Bg}"
                        BorderBrush="{DynamicResource Br.Border}"
                        BorderThickness="1"
                        MaxHeight="150"
                        MinWidth="{Binding ActualWidth,
                                                   RelativeSource={RelativeSource AncestorType=ComboBox}}">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsPresenter/>
                  </ScrollViewer>
                </Border>
              </Popup>
              <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                          RelativeSource={RelativeSource TemplatedParent}}"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="0"
                            Cursor="Hand"/>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="ItemContainerStyle">
        <Setter.Value>
          <Style TargetType="ComboBoxItem">
            <!-- FIX 1: контент пункта растягивается на всю ширину строки -->
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{DynamicResource Br.Fg}"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Light"/>
            <Setter Property="Padding"     Value="8,5"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Style.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Br.Border}"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Br.Border}"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <!-- ════════════════════════════════════════════════════════════════════
         ROOT — semi-transparent border card
         ════════════════════════════════════════════════════════════════════ -->
  <Border x:Name="RootCard"
          Background="{DynamicResource Br.Bg}"
          BorderBrush="{DynamicResource Br.Border}"
          BorderThickness="1"
          MouseLeftButtonDown="Window_MouseDown">
    <Border.Effect>
      <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.4" Color="Black"/>
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="28"/>
        <!-- custom title bar -->
        <RowDefinition Height="*"/>
        <!-- content -->
      </Grid.RowDefinitions>

      <!-- ═══ CUSTOM TITLE BAR ════════════════════════════════════════ -->
      <Grid Grid.Row="0"
            Background="Transparent"
            MouseLeftButtonDown="Window_MouseDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- app name pill -->
        <TextBlock Text="VOID VPN"
                   FontSize="9" FontWeight="Light"
                   Foreground="{DynamicResource Br.Muted}"
                   VerticalAlignment="Center"
                   Margin="14,0,0,0"/>

        <!-- Chrome buttons — tray + close -->
        <StackPanel Grid.Column="1" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="0,0,8,0">
          <Button x:Name="BtnTray"
                  Content="—"
                  Style="{StaticResource ChromeBtn}"
                  Click="BtnTray_Click"
                  ToolTip="Hide to tray"/>
          <Button x:Name="BtnClose"
                  Content="✕"
                  Style="{StaticResource ChromeBtn}"
                  Click="BtnClose_Click"
                  Margin="4,0,0,0"/>
        </StackPanel>
      </Grid>

      <!-- ═══ CONTENT (Simple + Beta views share row 1) ════════════════ -->
      <Grid Grid.Row="1">

        <!-- ══ SIMPLE VIEW ══════════════════════════════════════════ -->
        <Grid x:Name="SimpleView">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center">

            <TextBlock x:Name="TitleSimple"
                       Text="VOID VPN"
                       FontSize="24" FontWeight="Light"
                       Foreground="{DynamicResource Br.Fg}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,1"/>

            <TextBlock x:Name="StatusSimple"
                       Text="{Binding StatusText}"
                       FontSize="10" FontWeight="Light"
                       Foreground="{DynamicResource Br.Muted}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,22"/>

            <!-- 3-dot animation -->
            <Border x:Name="AnimBorder"
                    Width="84" Height="30" CornerRadius="15"
                    BorderBrush="{DynamicResource Br.Border}"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,22"
                    Visibility="Collapsed">
              <Canvas Width="56" Height="8"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                <Ellipse x:Name="Dot1" Width="8" Height="8"
                         Fill="{DynamicResource Br.Fg}" Canvas.Left="0"  Canvas.Top="0"/>
                <Ellipse x:Name="Dot2" Width="8" Height="8"
                         Fill="{DynamicResource Br.Fg}" Canvas.Left="20" Canvas.Top="0"/>
                <Ellipse x:Name="Dot3" Width="8" Height="8"
                         Fill="{DynamicResource Br.Fg}" Canvas.Left="40" Canvas.Top="0"/>
              </Canvas>
            </Border>

            <!-- Parse error -->
            <TextBlock x:Name="ParseErrSimple"
                       Text="{Binding ParseError}"
                       FontSize="9" FontWeight="Light"
                       Foreground="#CC3333"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" Width="260"
                       Margin="0,0,0,6"
                       Visibility="Collapsed"/>

            <!-- Key input + SAVE button -->
            <Grid Width="270" Margin="0,0,0,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Grid Grid.Column="0">
                <TextBox x:Name="TxtKeySimple"
                         Style="{StaticResource Input}"
                         Text="{Binding RawKey, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TxtKey_GotFocus"
                         LostFocus="TxtKey_LostFocus"/>
                <TextBlock x:Name="PhSimple"
                           Text="vless://  or  ss://"
                           FontSize="11" FontWeight="Light"
                           Foreground="{DynamicResource Br.Muted}"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Opacity="0.45"/>
              </Grid>
              <!-- SAVE: persists key to profile list so user doesn't re-paste every time -->
              <Button Grid.Column="1"
                      Content="SAVE"
                      Style="{StaticResource SmBtn}"
                      Command="{Binding AddKeyCommand}"
                      ToolTip="Save to profile list"
                      Margin="8,0,0,0"/>
            </Grid>

            <!-- Saved profiles dropdown – visible once at least one profile exists -->
            <Grid Width="270" Margin="0,0,0,20">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <ComboBox x:Name="ProfilesComboSimple"
                        ItemsSource="{Binding Profiles}"
                        SelectedItem="{Binding SelectedProfile}"
                        Style="{StaticResource ProfileCombo}"
                        Margin="0,0,8,0">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}"
                               FontSize="10" FontWeight="Light"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <Button Grid.Column="1"
                      Content="✕"
                      Style="{StaticResource GhostBtn}"
                      Command="{Binding DeleteKeyCommand}"
                      ToolTip="Remove selected profile"
                      FontSize="10"
                      VerticalAlignment="Center"/>
            </Grid>

            <Button x:Name="BtnMainConnect"
                    Content="CONNECT"
                    Style="{StaticResource Btn}"
                    Click="BtnMainConnect_Click"
                    HorizontalAlignment="Center"
                    Width="190"/>
          </StackPanel>

          <!-- Bottom bar -->
          <Grid Grid.Row="1" Margin="20,0,20,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding SpeedText}"
                       FontSize="8" FontWeight="Light"
                       Foreground="{DynamicResource Br.Muted}"
                       Opacity="0.6" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,10,0">
              <RadioButton x:Name="ThemeDarkS" GroupName="ThemeS" IsChecked="True"
                           Checked="ThemeDark_Checked" Cursor="Hand" Margin="0,0,7,0">
                <RadioButton.Template>
                  <ControlTemplate TargetType="RadioButton">
                    <Ellipse Width="10" Height="10" Fill="#111" Stroke="#444" StrokeThickness="1"/>
                  </ControlTemplate>
                </RadioButton.Template>
              </RadioButton>
              <RadioButton x:Name="ThemeLightS" GroupName="ThemeS"
                           Checked="ThemeLight_Checked" Cursor="Hand">
                <RadioButton.Template>
                  <ControlTemplate TargetType="RadioButton">
                    <Ellipse Width="10" Height="10" Fill="#EEE" Stroke="#BBB" StrokeThickness="1"/>
                  </ControlTemplate>
                </RadioButton.Template>
              </RadioButton>
            </StackPanel>

            <Button Grid.Column="2" Content="β BETA"
                    Style="{StaticResource SmBtn}"
                    Click="BtnToggleMode_Click"/>
          </Grid>
        </Grid>

        <!-- ══ BETA VIEW ════════════════════════════════════════════ -->
        <Grid x:Name="BetaView" Visibility="Collapsed" Margin="20,10,20,14">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0 header      -->
            <RowDefinition Height="Auto"/>
            <!-- 1 status card -->
            <RowDefinition Height="Auto"/>
            <!-- 2 key input   -->
            <RowDefinition Height="*"/>
            <!-- 3 keys list   -->
            <RowDefinition Height="118"/>
            <!-- 4 log panel   -->
            <RowDefinition Height="Auto"/>
            <!-- 5 footer      -->
          </Grid.RowDefinitions>

          <!-- Header -->
          <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
              <TextBlock Text="VOID VPN"
                         FontSize="14" FontWeight="Light"
                         Foreground="{DynamicResource Br.Fg}"/>
              <!-- subtitle row with kill-switch badge -->
              <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                <TextBlock Text="β beta  ·  sing-box 1.13.4  ·  tun"
                           FontSize="9" FontWeight="Light"
                           Foreground="{DynamicResource Br.Muted}"
                           Opacity="0.6" VerticalAlignment="Center"/>
                <Ellipse Width="5" Height="5" Fill="#44CC44"
                         VerticalAlignment="Center" Margin="8,0,4,0"/>
                <TextBlock Text="KS"
                           FontSize="8" FontWeight="Light"
                           Foreground="#44CC44" Opacity="0.8"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
              <RadioButton x:Name="ThemeDarkB" GroupName="ThemeB" IsChecked="True"
                           Checked="ThemeDark_Checked" Cursor="Hand" Margin="0,0,7,0">
                <RadioButton.Template>
                  <ControlTemplate TargetType="RadioButton">
                    <Ellipse Width="10" Height="10" Fill="#111" Stroke="#444" StrokeThickness="1"/>
                  </ControlTemplate>
                </RadioButton.Template>
              </RadioButton>
              <RadioButton x:Name="ThemeLightB" GroupName="ThemeB"
                           Checked="ThemeLight_Checked" Cursor="Hand">
                <RadioButton.Template>
                  <ControlTemplate TargetType="RadioButton">
                    <Ellipse Width="10" Height="10" Fill="#EEE" Stroke="#BBB" StrokeThickness="1"/>
                  </ControlTemplate>
                </RadioButton.Template>
              </RadioButton>
            </StackPanel>
          </Grid>

          <!-- Status card -->
          <Border Grid.Row="1"
                  BorderBrush="{DynamicResource Br.Border}"
                  BorderThickness="1"
                  Padding="12,9" Margin="0,0,0,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <Ellipse Width="5" Height="5"
                       Fill="{DynamicResource Br.StatusDot}"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusUpper}"
                           FontSize="10" FontWeight="Light"
                           Foreground="{DynamicResource Br.Fg}"/>
                <TextBlock Text="{Binding DetailText}"
                           FontSize="9" FontWeight="Light"
                           Foreground="{DynamicResource Br.Muted}"
                           Opacity="0.7" Margin="0,2,0,0"
                           TextWrapping="Wrap"/>
              </StackPanel>

              <StackPanel Grid.Column="2" Orientation="Horizontal"
                          VerticalAlignment="Center">
                <Button Content="CONNECT"
                        Style="{StaticResource SmBtn}"
                        Command="{Binding ConnectCommand}"
                        Margin="0,0,6,0"/>
                <Button Content="STOP"
                        Style="{StaticResource SmBtn}"
                        Command="{Binding DisconnectCommand}"
                        Width="44"/>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Key input + ADD -->
          <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Grid>
                <TextBox x:Name="TxtKeyBeta"
                         Style="{StaticResource Input}"
                         Text="{Binding RawKey, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TxtKey_GotFocus"
                         LostFocus="TxtKey_LostFocus"/>
                <TextBlock x:Name="PhBeta"
                           Text="vless://  or  ss://"
                           FontSize="11" FontWeight="Light"
                           Foreground="{DynamicResource Br.Muted}"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Opacity="0.45"/>
              </Grid>
              <Button Grid.Column="1" Content="ADD"
                      Style="{StaticResource SmBtn}"
                      Command="{Binding AddKeyCommand}"
                      Margin="10,0,0,0"/>
            </Grid>
            <TextBlock x:Name="ParseErrBeta" Grid.Row="1"
                       Text="{Binding ParseError}"
                       FontSize="9" FontWeight="Light"
                       Foreground="#CC3333"
                       Margin="0,3,0,0"
                       Visibility="Collapsed"/>
          </Grid>

          <!-- Saved keys list -->
          <Grid Grid.Row="3">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="SAVED KEYS"
                       FontSize="8" FontWeight="Light"
                       Foreground="{DynamicResource Br.Muted}"
                       Opacity="0.5" Margin="0,0,0,4"/>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding SelectedProfile}"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource KeyCard}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="False">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <!-- FIX 2: отступ слева 10px — название не прижато к границе -->
                  <Grid Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="{Binding Name}"
                                 FontSize="11" FontWeight="Light"
                                 Foreground="{DynamicResource Br.Fg}"/>
                      <TextBlock Text="{Binding DisplayHost}"
                                 FontSize="9" FontWeight="Light"
                                 Foreground="{DynamicResource Br.Muted}"
                                 Opacity="0.6" Margin="0,2,0,0"/>
                    </StackPanel>
                    <!-- Protocol on right, 8px padding from edge -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding DisplayProto}"
                               FontSize="8" FontWeight="Light"
                               Foreground="{DynamicResource Br.Muted}"
                               Opacity="0.45"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>

          <!-- Log panel with custom horizontal scrollbar -->
          <Border Grid.Row="4"
                  BorderBrush="{DynamicResource Br.Border}"
                  BorderThickness="1"
                  Margin="0,4,0,0">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <!-- Log header -->
              <Grid Margin="8,0,8,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock Text="LOG"
                             FontSize="8" FontWeight="Light"
                             Foreground="{DynamicResource Br.Muted}"
                             Opacity="0.5" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding LogCount}"
                             FontFamily="Consolas" FontSize="8"
                             Foreground="{DynamicResource Br.Muted}"
                             Opacity="0.35" Margin="5,0,0,0"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                  <Button Content="COPY"
                          Style="{StaticResource GhostBtn}"
                          Command="{Binding CopyLogCommand}"
                          Margin="0,0,10,0"/>
                  <Button Content="CLEAR"
                          Style="{StaticResource GhostBtn}"
                          Command="{Binding ClearLogCommand}"/>
                </StackPanel>
              </Grid>

              <!-- Log rows — custom ScrollViewer with minimal h-scrollbar -->
              <ScrollViewer x:Name="LogScroll"
                            Grid.Row="1"
                            Style="{StaticResource LogScrollViewer}"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Auto"
                            CanContentScroll="False"
                            Margin="0,0,0,0">
                <ItemsControl ItemsSource="{Binding LogEntries}"
                              Margin="8,2,8,2"
                              Focusable="False">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,0.5,0,0.5">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="54"/>
                          <ColumnDefinition Width="24"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Time}"
                                   Style="{StaticResource LogTime}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Tag}"
                                   Style="{StaticResource LogTag}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Message}"
                                   Style="{StaticResource LogMsg}"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>

          <!-- Footer -->
          <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding LocalPortText}"
                       FontSize="8" FontWeight="Light"
                       Foreground="{DynamicResource Br.Muted}"
                       Opacity="0.5" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="REMOVE"
                    Style="{StaticResource SmBtn}"
                    Command="{Binding DeleteKeyCommand}"
                    Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="← SIMPLE"
                    Style="{StaticResource SmBtn}"
                    Click="BtnToggleMode_Click"/>
          </Grid>
        </Grid>

      </Grid>
      <!-- /content grid row 1 -->
    </Grid>
  </Border>
</Window>
